# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Multi-Library Configuration
LIBRARIES_CONFIG_PATH=./data/libraries/config.yaml
DEFAULT_LIBRARY=harmonyos

# Document Source (Legacy - for backward compatibility)
DOCS_SOURCE_PATH=/home/mind/workspace/harmonyos/docs/zh-cn/application-dev

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
EMBEDDING_DEVICE=cpu  # or cuda

# Vector Store
CHROMA_PERSIST_DIR=./data/vectorstore
COLLECTION_NAME=harmony_docs  # Legacy collection name (will be migrated to lib_harmonyos)

# LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Retrieval
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Reranker Configuration
# Enable/disable reranker for improved retrieval precision
USE_RERANKER=true
# Reranker type: score_boost (fast), bm25 (keyword-based), cross_encoder (highest precision), none (disabled)
RERANKER_TYPE=cross_encoder
# Cross-Encoder model (only used when RERANKER_TYPE=cross_encoder)
# Options: BAAI/bge-reranker-v2-m3 (recommended), BAAI/bge-reranker-large
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3

# API Authentication (Optional)
# Set API_KEY_REQUIRED=true to enable authentication
API_KEY_REQUIRED=false
# Comma-separated list of valid API keys
API_KEYS=dev-key-12345,prod-key-67890

# Rate Limiting (Optional)
# Set RATE_LIMIT_ENABLED=true to enable rate limiting
RATE_LIMIT_ENABLED=false
# Maximum requests per minute per IP
RATE_LIMIT_PER_MINUTE=60
# Maximum requests per hour per IP
RATE_LIMIT_PER_HOUR=1000
